    "@types/express": "^5.0.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.0.0-beta.8",
    "tsx": "^4.22.3",
